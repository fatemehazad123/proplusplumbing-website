# Resend — transactional email API for the /contact form and /api/newsletter.
# Get a key at https://resend.com/api-keys.
# In production, set this in Vercel project settings (Environment Variables).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Search Console — paste the verification token after claiming the
# property at https://search.google.com/search-console. When set, the
# meta google-site-verification tag is emitted in <head>. Unset = no tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 — paste the measurement ID (G-XXXXXXXXXX) after
# creating a GA4 property at https://analytics.google.com. When set, the
# gtag.js script loads with anonymize_ip enabled. Unset = no analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
